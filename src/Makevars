# List all source files
SOURCES=$(wildcard *.cpp)

# Define objects from sources
OBJECTS=$(SOURCES:.cpp=.o)

# Add additional flags if needed
PKG_CPPFLAGS=-I.
PKG_CXXFLAGS += -O2
PKG_CFLAGS += -O2

# Define the rule for making the shared library
all: $(SHLIB)

# Clean up objects after build
clean:
	@rm -f $(OBJECTS) $(SHLIB)
