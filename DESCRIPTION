Package: richStudio
Type: Package
Title: Interactive Visualization and Clustering of Functional Enrichment Results
Version: 0.1.5
Date: 2025-12-05
Authors@R: c(
    person("Junguk", "Hur", email = "hurlabshared@gmail.com",
           role = c("aut", "cre"), comment = c(ORCID = "0000-0002-0736-2149")),
